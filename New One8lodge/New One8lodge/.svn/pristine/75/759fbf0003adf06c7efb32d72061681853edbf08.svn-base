package com.hotel.hotel_management.dtos;

import java.util.List;

import com.hotel.hotel_management.model.StoredImages;
import com.hotel.hotel_management.utility.IdenetityType;

public class RelatedCustomerDTO {
	
    private Long related_customer_id;
    private String name;
    private IdenetityType idenetityType;
    private List<StoredImages> images;
    
	public RelatedCustomerDTO(Long related_customer_id, String name,List<StoredImages> images) {
		super();
		this.related_customer_id = related_customer_id;
		this.name = name;
		this.images = images;
	}

	public RelatedCustomerDTO() {
		super();
		// TODO Auto-generated constructor stub
	}
	
	public IdenetityType getIdenetityType() {
		return idenetityType;
	}

	public void setIdenetityType(IdenetityType idenetityType) {
		this.idenetityType = idenetityType;
	}

	public Long getRelated_customer_id() {
		return related_customer_id;
	}

	public void setRelated_customer_id(Long related_customer_id) {
		this.related_customer_id = related_customer_id;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public List<StoredImages> getImages() {
		return images;
	}

	public void setImages(List<StoredImages> images) {
		this.images = images;
	}
	   
}
