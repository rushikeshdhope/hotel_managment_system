package com.hotel.hotel_management.dtos;

public class CustomerOrderDTO {

	private Customers1DTO customers1Dto;
	private Order1DTO order1dto;

	public Customers1DTO getCustomers1Dto() {
		return customers1Dto;
	}

	public void setCustomers1Dto(Customers1DTO customers1Dto) {
		this.customers1Dto = customers1Dto;
	}

	public Order1DTO getOrder1dto() {
