package com.hotel.hotel_management.dtos;

public class RoomSaleDTO {
	
	private Long room_number_count;
	private Long total_paid_room_amount;
	
	public Long getRoom_number_count() {
		return room_number_count;
	}
	public void setRoom_number_count(Long room_number_count) {
		this.room_number_count = room_number_count;
	}
	public Long getTotal_paid_room_amount() {
		return total_paid_room_amount;
	}
	public void setTotal_paid_room_amount(Long total_paid_room_amount) {
		this.total_paid_room_amount = total_paid_room_amount;
	}
	

}
